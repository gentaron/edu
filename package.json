{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "postinstall": "prisma generate",
    "prebuild": "bun run scripts/validate-data.ts",
    "build:rag": "tsx scripts/build-rag-index.ts",
    "build": "bun run build:rag && next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "bun prisma/seed.ts",
    "db:seed:pve": "bun prisma/seed-pve.ts",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "bench:rust": "cd crates/edu-battle-engine && cargo bench",
    "size": "bash scripts/measure-bundle-size.sh",
    "size:json": "bash scripts/measure-bundle-size.sh --json",
    "baseline": "bash scripts/capture-baseline.sh",
    "build:rag:dry": "tsx scripts/build-rag-index.ts --dry-run",
    "build:rag:force": "tsx scripts/build-rag-index.ts --force"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@sentry/nextjs": "^10.49.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@webgpu/types": "^0.1.69",
    "@xenova/transformers": "^2.17.2",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "fast-check": "^4.7.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=-1 --no-warn-ignored",
      "bash -c 'tsc --noEmit'"
    ],
    "*.{ts,tsx,css,json,md}": [
      "prettier --write"
    ]
  }
}
