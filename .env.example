# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/edu

# NextAuth
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Pinata IPFS (optional, for NFT features)
PINATA_JWT=

# Alchemy (optional, for NFT features)
ALCHEMY_API_KEY=
NEXT_PUBLIC_ZORA_CONTRACT=
NEXT_PUBLIC_PINATA_GATEWAY=

# ACE-Step Music Generation (optional)
# Start ACE-Step 1.5 with: python -m acestep --port 8001 --enable-api
ACESTEP_GRADIO_URL=http://localhost:8001
MUSIC_AUDIO_DIR=./public/music-audio

# Google Generative AI (for AI Enhance feature)
GEMINI_API_KEY=
